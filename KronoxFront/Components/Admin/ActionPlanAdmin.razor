    private async Task ToggleShowArchivedPublicly(ChangeEventArgs e)
    {
        if (actionPlan == null) return;

        var value = e.Value is bool b
            ? b
            : bool.TryParse(e.Value?.ToString(), out var parsed) && parsed;

        isSavingShowArchived = true;
        try
        {
            var http = HttpClientFactory.CreateClient("KronoxAPI");
            var response = await http.PutAsJsonAsync(
                $"api/ActionPlan/{pageKey}/show-archived",
                new SetShowArchivedDto { ShowArchivedPublicly = value });

            if (response.IsSuccessStatusCode)
            {
                actionPlan.ShowArchivedPublicly = value;
                Cms.InvalidateActionPlanCache(pageKey);
                await Toast.Success(value
                    ? "Avslutat-listan visas nu för besökare."
                    : "Avslutat-listan döljs för besökare.");
            }
            else
            {
                await Toast.Error("Kunde inte uppdatera synligheten.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Fel vid uppdatering av arkivsynlighet");
            await Toast.Error("Ett fel inträffade vid uppdatering av synligheten.");
        }
        finally
        {
            isSavingShowArchived = false;
        }
    }

    private void OpenDeleteModal(ActionPlanItem item)
    {
        deletingItem = item;
        showDeleteModal = true;
    }

    private void CloseDeleteModal()
    {
        showDeleteModal = false;
        deletingItem = null;
    }

    private async Task ConfirmDelete()
    {
        if (deletingItem == null || actionPlan == null) return;

        isDeleting = true;
        try
        {
            var http = HttpClientFactory.CreateClient("KronoxAPI");
            var response = await http.DeleteAsync($"api/ActionPlan/{pageKey}/items/{deletingItem.Id}");

            if (response.IsSuccessStatusCode)
            {
                Cms.InvalidateActionPlanCache(pageKey);

                await Toast.Success("Åtgärden har tagits bort.");
                await LoadActionPlan();
                CloseDeleteModal();
            }
            else
            {
                await Toast.Error("Kunde inte ta bort åtgärden. Försök igen.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Fel vid borttagning av åtgärd");
            await Toast.Error("Ett fel inträffade vid borttagning. Försök igen.");
        }
        finally
        {
            isDeleting = false;
        }
    }

