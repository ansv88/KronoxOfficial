    {
        subgoalParent = parent;
        editingSubgoal = new ActionPlanSubgoal { Id = 0 };
        subgoalModel = new CreateActionPlanSubgoalDto();

        await DestroyEditorAsync(_subgoalEditorId);
        _subgoalEditorId = $"ap-subdetail-{Guid.NewGuid():N}";
        _subgoalEditorInitialized = false;

        showSubgoalModal = true;
        StateHasChanged();
    }

    private async Task OpenEditSubgoalModal(ActionPlanItem parent, ActionPlanSubgoal subgoal)
    {
        subgoalParent = parent;
        editingSubgoal = subgoal;
        subgoalModel = new CreateActionPlanSubgoalDto
        {
            Activity = subgoal.Activity,
            DetailedDescription = subgoal.DetailedDescription,
            PlannedDelivery = subgoal.PlannedDelivery,
            Completed = subgoal.Completed
        };

        await DestroyEditorAsync(_subgoalEditorId);
        _subgoalEditorId = $"ap-subdetail-{Guid.NewGuid():N}";
        _subgoalEditorInitialized = false;

        showSubgoalModal = true;
        StateHasChanged();
    }

    private async Task CloseSubgoalModal()
    {
        showSubgoalModal = false;
        await DestroyEditorAsync(_subgoalEditorId);
        _subgoalEditorInitialized = false;
        subgoalParent = null;
        editingSubgoal = null;
        subgoalModel = new CreateActionPlanSubgoalDto();
        StateHasChanged();
    }

    private async Task SaveSubgoal()
    {
        if (subgoalParent == null || editingSubgoal == null) return;

        isSavingSubgoal = true;
        try
        {
            var content = await ReadEditorAsync(_subgoalEditorId);
            if (content is not null) subgoalModel.DetailedDescription = content;

            var http = HttpClientFactory.CreateClient("KronoxAPI");
            HttpResponseMessage response = editingSubgoal.Id == 0
                ? await http.PostAsJsonAsync($"api/ActionPlan/{pageKey}/items/{subgoalParent.Id}/subgoals", subgoalModel)
                : await http.PutAsJsonAsync($"api/ActionPlan/{pageKey}/items/{subgoalParent.Id}/subgoals/{editingSubgoal.Id}", subgoalModel);

            if (response.IsSuccessStatusCode)
            {
                Cms.InvalidateActionPlanCache(pageKey);
                expandedItems.Add(subgoalParent.Id);
                await Toast.Success(editingSubgoal.Id == 0 ? "Delmål har lagts till!" : "Delmål har uppdaterats!");
                await LoadActionPlan();
                await CloseSubgoalModal();
            }
            else
            {
                await Toast.Error("Kunde inte spara delmålet. Försök igen.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Fel vid sparning av delmål");
            await Toast.Error("Ett fel inträffade vid sparning. Försök igen.");
        }
        finally
        {
            isSavingSubgoal = false;
        }
    }

    private async Task MoveSubgoal(ActionPlanItem parent, int subgoalId, int direction)
    {
        try
        {
            var http = HttpClientFactory.CreateClient("KronoxAPI");
            var response = await http.PostAsJsonAsync(
                $"api/ActionPlan/{pageKey}/items/{parent.Id}/subgoals/{subgoalId}/move", new { Direction = direction });

            if (response.IsSuccessStatusCode)
            {
                Cms.InvalidateActionPlanCache(pageKey);
                await LoadActionPlan();
            }
            else
            {
                await Toast.Error("Kunde inte flytta delmålet.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Fel vid flyttning av delmål");
            await Toast.Error("Ett fel inträffade vid flyttning.");
        }
    }

    private void OpenSubgoalDeleteModal(ActionPlanItem parent, ActionPlanSubgoal subgoal)
    {
        deletingSubgoalParent = parent;
        deletingSubgoal = subgoal;
        showSubgoalDeleteModal = true;
    }

    private void CloseSubgoalDeleteModal()
    {
        showSubgoalDeleteModal = false;
        deletingSubgoal = null;
        deletingSubgoalParent = null;
    }

    private async Task ConfirmDeleteSubgoal()
    {
        if (deletingSubgoal == null || deletingSubgoalParent == null) return;

        isDeletingSubgoal = true;
        try
        {
            var http = HttpClientFactory.CreateClient("KronoxAPI");
            var response = await http.DeleteAsync(
                $"api/ActionPlan/{pageKey}/items/{deletingSubgoalParent.Id}/subgoals/{deletingSubgoal.Id}");

            if (response.IsSuccessStatusCode)
            {
                Cms.InvalidateActionPlanCache(pageKey);
                await Toast.Success("Delmålet har tagits bort.");
                await LoadActionPlan();
                CloseSubgoalDeleteModal();
            }
            else
            {
                await Toast.Error("Kunde inte ta bort delmålet. Försök igen.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Fel vid borttagning av delmål");
            await Toast.Error("Ett fel inträffade vid borttagning. Försök igen.");
        }
        finally
        {
            isDeletingSubgoal = false;
        }
    }
}
