    protected override async Task OnInitializedAsync()
    {
        await LoadActionPlan();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (showEditModal && editingItem != null && !_detailsEditorInitialized)
        {
            _detailsEditorInitialized = true;
            await InitializeEditorAsync(_detailsEditorId);
        }

        if (showSubgoalModal && editingSubgoal != null && !_subgoalEditorInitialized)
        {
            _subgoalEditorInitialized = true;
            await InitializeEditorAsync(_subgoalEditorId);
        }

        try
        {
            await JS.InvokeVoidAsync("setCurrentPageKey", pageKey);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Kunde inte sätta currentPageKey för TinyMCE");
        }
    }

    public async ValueTask DisposeAsync()
    {
        try { await DestroyEditorAsync(_detailsEditorId); } catch { }
        try { await DestroyEditorAsync(_subgoalEditorId); } catch { }
        try { await JS.InvokeVoidAsync("clearCurrentPageKey"); } catch { }
    }

    // Normalisera TinyMCE-HTML för att säkra bildvisning i panelen.
    private static string NormalizeHtml(string? html)
    {
        if (string.IsNullOrWhiteSpace(html)) return string.Empty;

        var fixedHtml = html;
        fixedHtml = Regex.Replace(fixedHtml, @"\sdata-mce-src\s*=\s*""", " src=\"", RegexOptions.IgnoreCase);
        fixedHtml = Regex.Replace(fixedHtml, @"\sdata-mce-src\s*=\s*'", " src='", RegexOptions.IgnoreCase);
        fixedHtml = Regex.Replace(fixedHtml, "src=\"(images/)", "src=\"/images/", RegexOptions.IgnoreCase);
        fixedHtml = Regex.Replace(fixedHtml, "src='(images/)", "src='/images/", RegexOptions.IgnoreCase);
        return fixedHtml;
    }

    private void ToggleItem(int itemId)
    {
        if (!expandedItems.Remove(itemId))
            expandedItems.Add(itemId);
    }

    // Panel som visar detaljerad beskrivning och delmål under en åtgärd.
    private RenderFragment RenderItemPanel(ActionPlanItem item, bool hasDetails, bool hasSubgoals, bool allowEdit) => __builder =>
    {
        if (hasDetails)
        {
            <small class="text-muted fw-bold">Detaljerad beskrivning:</small>
            <div class="mt-2 detailed-html">@((MarkupString)NormalizeHtml(item.DetailedDescription))</div>
        }

        @if (hasSubgoals)
        {
            <div class="@(hasDetails ? "mt-3" : "")">
                <small class="text-muted fw-bold">
                    <i class="fa-solid fa-diagram-project me-1"></i>Delmål:
                </small>
                <div class="table-responsive mt-2">
                    <table class="table table-sm mb-0 align-middle">
                        <thead>
                            <tr>
                                <th>Delmål</th>
                                <th class="text-center" style="width: 9rem;">Planerad leverans</th>
                                <th class="text-center" style="width: 6rem;">Avklarad</th>
                                @if (allowEdit)
                                {
                                    <th style="width: 10rem;">Åtgärder</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var sortedSubgoals = item.Subgoals.OrderBy(s => s.SortOrder).ToList();
                            }
                            @for (int sgi = 0; sgi < sortedSubgoals.Count; sgi++)
                            {
                                var subgoal = sortedSubgoals[sgi];
                                var sgIndex = sgi;
                                var hasSubDetails = !string.IsNullOrWhiteSpace(subgoal.DetailedDescription);
                                <tr>
                                    <td class="text-break">
                                        <i class="fa-solid fa-turn-up fa-rotate-90 text-muted me-1"></i>
                                        @subgoal.Activity
                                    </td>
                                    <td class="text-center">@subgoal.PlannedDelivery</td>
                                    <td class="text-center">
                                        @if (!string.IsNullOrWhiteSpace(subgoal.Completed))
                                        {
                                            <span class="badge bg-success">@subgoal.Completed</span>
                                        }
                                    </td>
                                    @if (allowEdit)
                                    {
                                        <td>
                                            <div class="btn-group btn-group-sm" role="group">
                                                <button type="button" class="btn btn-outline-primary"
                                                        @onclick="@(() => OpenEditSubgoalModal(item, subgoal))" title="Redigera delmål">
                                                    <i class="fa-solid fa-edit"></i>
                                                </button>
                                                <button type="button" class="btn btn-outline-secondary"
                                                        @onclick="@(() => MoveSubgoal(item, subgoal.Id, -1))"
                                                        disabled="@(sgIndex == 0)" title="Flytta upp">
                                                    <i class="fa-solid fa-arrow-up"></i>
                                                </button>
                                                <button type="button" class="btn btn-outline-secondary"
                                                        @onclick="@(() => MoveSubgoal(item, subgoal.Id, 1))"
                                                        disabled="@(sgIndex == sortedSubgoals.Count - 1)" title="Flytta ner">
                                                    <i class="fa-solid fa-arrow-down"></i>
                                                </button>
                                                <button type="button" class="btn btn-outline-danger"
                                                        @onclick="@(() => OpenSubgoalDeleteModal(item, subgoal))" title="Ta bort delmål">
                                                    <i class="fa-solid fa-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    }
                                </tr>
                                @if (hasSubDetails)
                                {
                                    <tr>
                                        <td colspan="@(allowEdit ? 4 : 3)">
                                            <div class="ps-4 detailed-html">@((MarkupString)NormalizeHtml(subgoal.DetailedDescription))</div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    };

    // Dataladdning
    private async Task LoadActionPlan()
    {
        isLoading = true;
        hasError = false;

        try
        {
            var http = HttpClientFactory.CreateClient("KronoxAPI");
            var response = await http.GetFromJsonAsync<ActionPlanTableDto>($"api/ActionPlan/{pageKey}?includeArchived=true");

            if (response != null)
            {
                actionPlan = new ActionPlanTableViewModel
                {
                    Id = response.Id,
                    PageKey = response.PageKey,
                    LastModified = response.LastModified,
                    ShowArchivedPublicly = response.ShowArchivedPublicly,
                    Items = response.Items.Select(MapItem).ToList(),
                    ArchivedItems = response.ArchivedItems.Select(MapItem).ToList()
                };
            }
            else
            {
                actionPlan = new ActionPlanTableViewModel
                {
                    PageKey = pageKey,
                    Items = new List<ActionPlanItem>()
                };
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Fel vid laddning av handlingsplan");
            hasError = true;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private static ActionPlanItem MapItem(ActionPlanItemDto i) => new()
    {
        Id = i.Id,
        Module = i.Module,
        Activity = i.Activity,
        DetailedDescription = i.DetailedDescription,
        PlannedDelivery = i.PlannedDelivery,
        Completed = i.Completed,
        SortOrder = i.SortOrder,
        IsArchived = i.IsArchived,
        ArchivedAt = i.ArchivedAt,
        Subgoals = i.Subgoals?.Select(s => new ActionPlanSubgoal
        {
            Id = s.Id,
            Activity = s.Activity,
            DetailedDescription = s.DetailedDescription,
            PlannedDelivery = s.PlannedDelivery,
            Completed = s.Completed,
            SortOrder = s.SortOrder
        }).ToList() ?? new List<ActionPlanSubgoal>()
    };

    // TinyMCE-hjälpmetoder (delas mellan åtgärds- och delmålseditorn)
    private async Task InitializeEditorAsync(string editorId)
    {
        try
        {
            await Task.Delay(150);

            var exists = await JS.InvokeAsync<bool>("elementExists", editorId);
            if (exists)
            {
                await JS.InvokeVoidAsync("initTinyMCE", editorId);

                var ready = await JS.InvokeAsync<bool>("tinymceExists", editorId);
                if (!ready)
                {
                    await Task.Delay(100);
                    await JS.InvokeVoidAsync("initTinyMCE", editorId);
                }

                Logger.LogInformation("TinyMCE initialiserad för {EditorId}", editorId);
            }
            else
            {
                Logger.LogWarning("Element {EditorId} hittades inte i DOM", editorId);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Fel vid init av TinyMCE {EditorId}", editorId);
        }
    }

    private async Task<string?> ReadEditorAsync(string editorId)
    {
        try
        {
            var editorExists = await JS.InvokeAsync<bool>("tinymceExists", editorId);
            if (editorExists)
            {
                return await JS.InvokeAsync<string>("eval",
                    $"tinymce.get('{editorId}') ? tinymce.get('{editorId}').getContent() : ''");
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Kunde inte synka TinyMCE {EditorId}", editorId);
        }
        return null;
    }

    private async Task DestroyEditorAsync(string editorId)
    {
        try
        {
            var editorExists = await JS.InvokeAsync<bool>("tinymceExists", editorId);
            if (editorExists)
            {
                await JS.InvokeVoidAsync("eval", $"tinymce.get('{editorId}')?.destroy()");
                Logger.LogInformation("TinyMCE förstörd för {EditorId}", editorId);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Fel vid destroy av TinyMCE {EditorId}", editorId);
        }
    }

    private async Task OpenCreateModal()
    {
        try
        {
            actionPlan ??= new ActionPlanTableViewModel
            {
                PageKey = pageKey,
                Items = new List<ActionPlanItem>()
            };

            editingItem = new ActionPlanItem { Id = 0 };
            editModel = new CreateActionPlanItemDto();

            await DestroyEditorAsync(_detailsEditorId);
            _detailsEditorId = $"ap-detail-{Guid.NewGuid():N}";
            _detailsEditorInitialized = false;

            showEditModal = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "OpenCreateModal failed");
            _ = Toast.Error("Ett fel inträffade vid öppning av dialog.");
        }
    }

    private async Task OpenEditModal(ActionPlanItem item)
    {
        try
        {
            editingItem = item;
            editModel = new CreateActionPlanItemDto
            {
                Module = item.Module ?? "",
                Activity = item.Activity ?? "",
                DetailedDescription = item.DetailedDescription ?? "",
                PlannedDelivery = item.PlannedDelivery ?? "",
                Completed = item.Completed ?? ""
            };

            await DestroyEditorAsync(_detailsEditorId);
            _detailsEditorId = $"ap-detail-{Guid.NewGuid():N}";
            _detailsEditorInitialized = false;

            showEditModal = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "OpenEditModal failed");
            _ = Toast.Error("Ett fel inträffade vid öppning av dialog.");
