@page "/admin/images"
@attribute [Authorize]
@attribute [Authorize(Roles = "Admin")]
@layout AdminLayout
@using KronoxFront.DTOs
@using KronoxFront.Components.Shared.UI
@using KronoxFront.Services
@using KronoxFront.ViewModels
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@inject CmsService Cms
@inject IToastService Toast
@inject IJSRuntime JS
@inject ILogger<ImagesAdmin> Logger

<h1 class="h5 mb-3"><i class="fa-solid fa-images me-2"></i>Hantera bilder</h1>

@* ── Informationsruta ── *@
<div class="alert alert-info border-0 shadow-sm mb-4" role="note">
    <div class="d-flex align-items-start gap-2">
        <i class="fa-solid fa-circle-info mt-1 flex-shrink-0"></i>
        <div>
            <strong>Så fungerar bildhanteringen</strong>
            <ul class="mb-0 mt-1 ps-3 small">
                <li>Här laddar du upp och tar bort bilder. Biblioteket är en <strong>lagringsplats</strong> – själva placeringen av bilder styrs på respektive sida.</li>
                <li><span class="badge bg-success"><i class="fa-solid fa-circle-check me-1"></i>Bannerbild</span> visar att bilden just nu används som <strong>bannerbild</strong> på en sida.</li>
                <li>För att byta banner-, intro- eller sektionsbild går du till motsvarande sida och redigerar den där.</li>
                <li>Bilder som <strong>används</strong> någonstans kan inte tas bort – byt ut eller ta bort dem på sidan först.</li>
                <li>Medlemslogotyper hanteras separat under <a href="/admin/memberlogos" class="alert-link">Medlemslogotyper</a>.</li>
            </ul>
        </div>
    </div>
</div>

@* ── Ladda upp nya bilder ── *@
<div class="card mb-4 shadow-sm border-primary border-opacity-25">
    <div class="card-header bg-primary bg-opacity-10 py-2 d-flex align-items-center gap-2">
        <i class="fa-solid fa-upload text-primary"></i>
        <strong class="small text-primary">Ladda upp nya bilder</strong>
    </div>
    <div class="card-body p-3">

        @* Steg 1: Välj filer *@
        <div class="mb-3">
            <label class="form-label small fw-semibold mb-1">
                <span class="badge bg-primary me-1">1</span> Välj bilder att ladda upp
            </label>
            <InputFile OnChange="FilesSelected"
                       multiple
                       accept="image/jpeg,image/png,image/gif,image/webp,image/svg+xml"
                       class="form-control form-control-sm"
                       aria-label="Välj bilder att ladda upp" />
            <div class="form-text">Tillåtna format: JPG, PNG, GIF, WebP, SVG. Max 10 MB per fil, max @MaxFiles filer åt gången.</div>
        </div>

        @* Steg 2 – visas när filer valts *@
        @if (uploadQueue.Count > 0)
        {
            <div class="border rounded p-3 bg-light mb-3">
                <div class="small fw-semibold mb-2">
                    <span class="badge bg-primary me-1">2</span> Ange information om bilderna
                </div>
                <div class="row g-2">
                    <div class="col-12 col-sm-6">
                        <label class="form-label small mb-1">
                            Sida (sidnyckel) <span class="text-danger">*</span>
                            <span class="text-muted fw-normal">– vilken sida tillhör bilderna?</span>
                        </label>
                        <input class="form-control form-control-sm"
                               list="uploadPageKeysList"
                               placeholder="Välj eller skriv sidnyckel, t.ex. home"
                               @bind="uploadPageKey" />
                        <datalist id="uploadPageKeysList">
                            <option value="bibliotek"></option>
                            @foreach (var key in pageKeys)
                            {
                                <option value="@key"></option>
                            }
                        </datalist>
                        <div class="form-text">Välj från listan eller skriv en ny nyckel.</div>
                    </div>
                    <div class="col-12 col-sm-6">
                        <label class="form-label small mb-1">
                            Bildbeskrivning (alt-text)
                            <span class="text-muted fw-normal">– valfritt, gäller alla valda filer</span>
                        </label>
                        <input type="text" class="form-control form-control-sm"
                               placeholder="Beskriv bildernas innehåll..."
                               @bind="uploadAltText" />
                        <div class="form-text">Används av skärmläsare och sökmotorer.</div>
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <div class="small fw-semibold mb-1">Valda filer (@uploadQueue.Count st):</div>
                <ul class="list-group list-group-flush small">
                    @foreach (var item in uploadQueue)
                    {
                        <li class="list-group-item px-0 py-1 d-flex align-items-center gap-2">
                            @if (item.Status == UploadStatus.Pending)
                            {
                                <i class="fa-regular fa-circle text-muted" title="Väntar"></i>
                            }
                            else if (item.Status == UploadStatus.Uploading)
                            {
                                <span class="spinner-border spinner-border-sm text-primary" role="status" aria-label="Laddar upp"></span>
                            }
                            else if (item.Status == UploadStatus.Done)
                            {
                                <i class="fa-solid fa-check text-success" title="Klar"></i>
                            }
                            else
                            {
                                <i class="fa-solid fa-xmark text-danger" title="Misslyckades"></i>
                            }
                            <span class="text-truncate" style="max-width:280px" title="@item.FileName">@item.FileName</span>
                            @if (!string.IsNullOrEmpty(item.ErrorMessage))
                            {
                                <span class="text-danger ms-1">— @item.ErrorMessage</span>
                            }
                        </li>
                    }
                </ul>
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-primary"
                        @onclick="UploadAll"
                        disabled="@(isUploading || uploadQueue.All(x => x.Status == UploadStatus.Done))">
                    @if (isUploading)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        <span>Laddar upp...</span>
                    }
                    else
                    {
                        <i class="fa-solid fa-upload me-1"></i>
                        <span>Ladda upp (@uploadQueue.Count(x => x.Status == UploadStatus.Pending) st)</span>
                    }
                </button>
                <button class="btn btn-sm btn-outline-secondary"
                        @onclick="ClearQueue"
                        disabled="@isUploading">
                    <i class="fa-solid fa-xmark me-1"></i>Rensa listan
                </button>
            </div>
        }
    </div>
</div>

@* ── Bildbibliotek ── *@
<div class="card shadow-sm border-success border-opacity-25">
    <div class="card-header bg-success bg-opacity-10 py-2 d-flex align-items-center justify-content-between gap-2 flex-wrap">
        <div class="d-flex align-items-center gap-2">
            <i class="fa-solid fa-images text-success"></i>
            <strong class="small text-success">Bildbibliotek</strong>
            @if (images.Count > 0)
            {
                <span class="badge bg-success bg-opacity-75">@images.Count st</span>
            }
        </div>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <input class="form-control form-control-sm"
                   style="max-width: 220px;"
                   list="pageKeysList"
                   placeholder="Filtrera på sida..."
                   @bind="filterPageKey" />
            <datalist id="pageKeysList">
                @foreach (var key in pageKeys)
                {
                    <option value="@key"></option>
                }
            </datalist>
            <button class="btn btn-sm btn-success" @onclick="Load" title="Filtrera bildbiblioteket">
                <i class="fa-solid fa-filter me-1"></i>Filtrera
            </button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="ShowAll" title="Rensa filter och visa alla bilder">
                <i class="fa-solid fa-list me-1"></i>Visa alla
            </button>
        </div>
    </div>
    <div class="card-body p-3">
        @if (isLoading)
        {
            <div class="text-muted py-3 text-center">
                <span class="spinner-border spinner-border-sm me-2" role="status"></span>Laddar bilder...
            </div>
        }
        else if (images.Count == 0)
        {
            <div class="alert alert-info py-2 mb-0">
                <i class="fa-solid fa-circle-info me-1"></i>
                @(string.IsNullOrWhiteSpace(filterPageKey)
                    ? "Inga bilder finns uppladdade än."
                    : $"Inga bilder hittades för sidan \"{filterPageKey}\".")
            </div>
        }
        else
        {
            <div class="row g-2">
                @foreach (var img in images)
                {
                    <div class="col-6 col-sm-4 col-md-3">
                        <div class="card h-100 shadow-sm position-relative"
                             style="@(img.IsActive ? "border: 2px solid #198754;" : "border: 1px solid rgba(0,0,0,.125);")">

                            <div class="ratio ratio-1x1" role="button" title="Klicka för att förhandsgranska" @onclick="() => Preview(img.Url)">
                                <img src="@img.Url"
                                     alt="@img.AltText"
                                     class="w-100 h-100 rounded-top"
                                     loading="lazy"
                                     decoding="async"
                                     style="object-fit: cover;" />
                            </div>

                            @if (img.IsActive)
                            {
                                <div class="position-absolute top-0 start-0 m-1">
                                    <span class="badge bg-success" title="Används som bannerbild på @img.PageKey"><i class="fa-solid fa-circle-check me-1"></i>Bannerbild</span>
                                </div>
                            }

                            <div class="card-body p-2">
                                @if (!string.IsNullOrWhiteSpace(img.PageKey))
                                {
                                    <span class="badge bg-secondary mb-1" title="Sidan denna bild tillhör">@img.PageKey</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-muted border mb-1" title="Ingen sida kopplad">Ingen sida</span>
                                }

                                <div class="small text-truncate fw-semibold" title="@img.Url">
                                    @System.IO.Path.GetFileName(img.Url)
                                </div>

                                @if (!string.IsNullOrWhiteSpace(img.AltText))
                                {
                                    <div class="small text-muted fst-italic text-truncate" title="@img.AltText">@img.AltText</div>
                                }

@{
    var usages = UsagesFor(img.Url);
    var isUsed = usages.Count > 0;
}

@if (isUsed)
{
    <div class="mt-2">
        <div class="small fw-semibold text-success"><i class="fa-solid fa-link me-1"></i>Används:</div>
        <ul class="mb-0 ps-3 small">
            @foreach (var u in usages.Select(u => u.Description).Distinct())
            {
                <li>@u</li>
            }
        </ul>
    </div>
}
else
{
    <div class="small text-muted mt-2"><i class="fa-regular fa-circle me-1"></i>Används inte</div>
}

<div class="mt-2 d-flex gap-1 flex-wrap">
    <button class="btn btn-outline-danger btn-sm px-2 py-1"
            title="@(isUsed ? "Bilden används – ta bort den på respektive sida först" : "Ta bort bilden permanent")"
            disabled="@isUsed"
            @onclick="() => DeleteEverywhere(img)">
        <i class="fa-solid fa-trash me-1"></i><span class="d-none d-sm-inline">Ta bort</span>
    </button>
</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<ImageModal ImageUrl="@previewUrl" OnClose="@ClosePreview" />

@code {
    private bool isLoading;
    private string? filterPageKey;
    private List<PageImageViewModel> images = new();
    private string? previewUrl;

    private Dictionary<string, List<ImageUsageDto>> usageByUrl = new(StringComparer.OrdinalIgnoreCase);
    private List<ImageUsageDto> UsagesFor(string url)
        => usageByUrl.TryGetValue(url, out var u) ? u : new();

    private List<string> pageKeys = new();

    private string uploadPageKey = "bibliotek";
    private string uploadAltText = "";
    private bool isUploading;
    private List<UploadItem> uploadQueue = new();

    private enum UploadStatus { Pending, Uploading, Done, Error }

    private class UploadItem
    {
        public required IBrowserFile File { get; init; }
        public string FileName => File.Name;
        public UploadStatus Status { get; set; } = UploadStatus.Pending;
        public string? ErrorMessage { get; set; }
    }

    private const int MaxFiles = 20;
    private const long MaxFileSize = 10_000_000; // 10 MB

    private void FilesSelected(InputFileChangeEventArgs e)
    {
        var selected = e.GetMultipleFiles(MaxFiles);
        uploadQueue = selected
            .Select(f => new UploadItem { File = f })
            .ToList();
    }

    private async Task UploadAll()
    {
        if (string.IsNullOrWhiteSpace(uploadPageKey))
        {
            await Toast.Warning("Ange en sidnyckel innan uppladdning.");
            return;
        }

        var pending = uploadQueue.Where(x => x.Status == UploadStatus.Pending).ToList();
        if (pending.Count == 0) return;

        isUploading = true;
        int successCount = 0;

        foreach (var item in pending)
        {
            item.Status = UploadStatus.Uploading;
            StateHasChanged();

            try
            {
                await using var stream = item.File.OpenReadStream(MaxFileSize);
                var result = await Cms.UploadPageImageAsync(
                    uploadPageKey.Trim(),
                    stream,
                    item.File.Name,
                    uploadAltText);

                if (result != null)
                {
                    item.Status = UploadStatus.Done;
                    successCount++;
                }
                else
                {
                    item.Status = UploadStatus.Error;
                    item.ErrorMessage = "Uppladdningen misslyckades.";
                }
            }
            catch (IOException)
            {
                item.Status = UploadStatus.Error;
                item.ErrorMessage = $"Filen är för stor (max {MaxFileSize / 1_000_000} MB).";
            }
            catch (Exception ex)
            {
                item.Status = UploadStatus.Error;
                item.ErrorMessage = ex.Message;
                Logger.LogError(ex, "Fel vid uppladdning av {FileName}", item.FileName);
            }

            StateHasChanged();
        }

        isUploading = false;

        if (successCount > 0)
        {
            await Toast.Success($"{successCount} bild(er) laddades upp till '{uploadPageKey}'.");
            await Load();
        }

        var errorCount = pending.Count(x => x.Status == UploadStatus.Error);
        if (errorCount > 0)
            await Toast.Error($"{errorCount} bild(er) misslyckades – se listan ovan.");
    }

    private void ClearQueue()
    {
        uploadQueue.Clear();
        uploadAltText = "";
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadPageKeys();
        await Load();
    }

    private async Task LoadPageKeys()
    {
        try
        {
            pageKeys = await Cms.GetAllPageKeysAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Kunde inte hämta PageKeys");
            await Toast.Warning($"Kunde inte hämta sidnycklar: {ex.Message}");
        }
    }

private async Task Load()
{
    isLoading = true;
    try
    {
        var all = await Cms.GetAllImagesAsync(filterPageKey);

        // Slå ihop rader som delar URL (referensrader) till ett kort
        images = all
            .GroupBy(i => i.Url, StringComparer.OrdinalIgnoreCase)
            .Select(g => g.OrderBy(i => i.PageKey == "bibliotek" ? 0 : 1).First())
            .ToList();

        var usages = await Cms.GetAllImageUsagesAsync();
        usageByUrl = usages
            .GroupBy(u => u.Url, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(g => g.Key, g => g.ToList(), StringComparer.OrdinalIgnoreCase);
    }
    catch (Exception ex)
    {
        Logger.LogError(ex, "Kunde inte hämta bilder");
        await Toast.Error($"Kunde inte hämta bilder: {ex.Message}");
    }
    finally
    {
        isLoading = false;
        StateHasChanged();
    }
}

    private async Task ShowAll()
    {
        filterPageKey = null;
        await Load();
    }

    private void Preview(string url) => previewUrl = url;
    private void ClosePreview() => previewUrl = null;

   private async Task DeleteEverywhere(PageImageViewModel img)
{
    var usages = UsagesFor(img.Url);
    if (usages.Count > 0)
    {
        await Toast.Warning("Bilden används och kan inte tas bort: "
            + string.Join(", ", usages.Select(u => u.Description).Distinct())
            + ". Ta bort den på respektive sida först.");
        return;
    }

    try
    {
        var ok = await JS.InvokeAsync<bool>("showConfirmDialog",
            $"Ta bort bilden '{System.IO.Path.GetFileName(img.Url)}'? Filen raderas permanent.");
        if (!ok) return;

        var (success, error) = await Cms.DeletePageImageAsync(img.PageKey, img.Id, img.Url);
        if (success)
        {
            await Toast.Success("Bilden har tagits bort.");
            await Load();
        }
        else
        {
            await Toast.Warning(error ?? "Bilden kunde inte tas bort eftersom den används.");
            await Load();
        }
    }
    catch (Exception ex)
    {
        await Toast.Error($"Kunde inte ta bort: {ex.Message}");
    }
}
}