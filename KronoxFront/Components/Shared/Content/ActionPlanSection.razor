@using KronoxFront.ViewModels
@using System.Text.RegularExpressions

@if (IsAdminContext)
{
    <div class="card mb-4">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <h3 class="h5 mb-0">
                <i class="fa-solid fa-list-check me-2" aria-hidden="true"></i>
                @(string.IsNullOrWhiteSpace(Title) ? "Handlingsplan" : Title)
            </h3>

            @if (ShowAdminButton)
            {
                <a href="@AdminButtonUrl" class="btn btn-outline-primary btn-sm" aria-label="Hantera handlingsplan">
                    <i class="fa-solid fa-clipboard-list me-1" aria-hidden="true"></i>
                    Hantera handlingsplan
                </a>
            }
        </div>
        <div class="card-body">
            @RenderActionPlanTable()
            @RenderArchivedTable()

            @{
                var lastModified = ActionPlan?.LastModified;
            }
            @if (lastModified is DateTime dt && dt != default)
            {
                <div class="text-center mt-3">
                    <small class="text-muted">
                        <i class="fa-solid fa-clock me-1" aria-hidden="true"></i>
                        Senast uppdaterad: @dt.ToString("yyyy-MM-dd HH:mm")
                    </small>
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="action-plan-container">
        @if (!string.IsNullOrEmpty(Title))
        {
            <h2 class="text-center mb-4">@Title</h2>
        }

        @RenderActionPlanTable()
        @RenderArchivedTable()

        @{
            var lastModified = ActionPlan?.LastModified;
        }
        @if (lastModified is DateTime dt && dt != default)
        {
            <div class="text-center mt-3">
                <small class="text-muted">
                    <i class="fa-solid fa-clock me-1" aria-hidden="true"></i>
                    Senast uppdaterad: @dt.ToString("yyyy-MM-dd HH:mm")
                </small>
            </div>
        }
    </div>
}

@code {
    [Parameter] public ActionPlanTableViewModel? ActionPlan { get; set; }
    [Parameter] public string? Title { get; set; } = "Handlingsplan";
    [Parameter] public bool ShowAdminButton { get; set; } = false;
    [Parameter] public string AdminButtonUrl { get; set; } = "/admin/actionplan";
    [Parameter] public bool IsAdminContext { get; set; } = false;

    // En enda uppfällbar panel per modul visar både detaljerad beskrivning och delmål.
    private HashSet<int> expandedItems = new();

    protected override void OnParametersSet()
    {
        // Trim och säkra standardvärden
        Title = string.IsNullOrWhiteSpace(Title) ? "Handlingsplan" : Title!.Trim();
        AdminButtonUrl = string.IsNullOrWhiteSpace(AdminButtonUrl) ? "/admin/actionplan" : AdminButtonUrl.Trim();
    }

    private RenderFragment RenderActionPlanTable() => __builder =>
    {
        var items = ActionPlan?.Items;

        if (items is not null && items.Any())
        {
            var sortedItems = items.OrderBy(i => i.SortOrder).ToList();

            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <colgroup>
                        <col style="width: 6rem;">
                        <col style="width: 10rem;">
                        <col>
                        <col style="width: 9rem;">
                        <col style="width: 6rem;">
                    </colgroup>
                    <thead class="table-dark">
                        <tr>
                            <th scope="col" class="text-center">Prioritering</th>
                            <th scope="col">Modul/del</th>
                            <th scope="col">Aktivitet</th>
                            <th scope="col" class="text-center">Planerad leverans</th>
                            <th scope="col" class="text-center">Avklarad</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < sortedItems.Count; i++)
                        {
                            var item = sortedItems[i];
                            var displayNumber = i + 1;
                            var hasDetails = !string.IsNullOrWhiteSpace(item.DetailedDescription);
                            var hasSubgoals = item.Subgoals is not null && item.Subgoals.Any();
                            var isExpandable = hasDetails || hasSubgoals;

                            <tr>
                                <td class="text-center"><span>@displayNumber</span></td>
                                <td><strong>@item.Module</strong></td>
                                <td>
                                    <div class="d-flex align-items-start">
                                        <div class="flex-grow-1 text-break">@item.Activity</div>
                                        @if (isExpandable)
                                        {
                                            <button type="button"
                                                    class="btn btn-link btn-sm p-0 ms-2 flex-shrink-0 align-baseline"
                                                    @onclick="() => ToggleItem(item.Id)"
                                                    title="Visa/dölj detaljer och delmål"
                                                    aria-label="Visa eller dölj detaljer och delmål för @item.Module">
                                                <i class="fa-solid @(expandedItems.Contains(item.Id) ? "fa-chevron-up" : "fa-chevron-down")" aria-hidden="true"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                                <td class="text-center"><span class="text-muted">@item.PlannedDelivery</span></td>
                                <td class="text-center">
                                    @RenderStatus(item.Completed)
                                </td>
                            </tr>

                            @if (expandedItems.Contains(item.Id) && isExpandable)
                            {
                                <tr class="table-light">
                                    <td colspan="5">
                                        <div class="p-3">
                                            @RenderItemPanel(item, hasDetails, hasSubgoals)
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center text-muted py-4">
                <i class="fa-solid fa-table fa-2x mb-2" aria-hidden="true"></i>
                <p>Ingen handlingsplan har lagts till än.</p>
            </div>
        }
    };

    private RenderFragment RenderItemPanel(ActionPlanItem item, bool hasDetails, bool hasSubgoals) => __builder =>
    {
        if (hasDetails)
        {
            <small class="text-muted fw-bold">Detaljerad beskrivning:</small>
            <div class="mt-2 detailed-html">@((MarkupString)NormalizeHtml(item.DetailedDescription))</div>
        }

        @if (hasSubgoals)
        {
            <div class="@(hasDetails ? "mt-3" : "")">
                <small class="text-muted fw-bold">
                    <i class="fa-solid fa-diagram-project me-1" aria-hidden="true"></i>Delmål:
                </small>
                <div class="table-responsive mt-2">
                    <table class="table table-sm mb-0 align-middle">
                        <colgroup>
                            <col>
                            <col style="width: 9rem;">
                            <col style="width: 6rem;">
                        </colgroup>
                        <thead>
                            <tr>
                                <th scope="col">Delmål</th>
                                <th scope="col" class="text-center">Planerad leverans</th>
                                <th scope="col" class="text-center">Avklarad</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var subgoal in item.Subgoals.OrderBy(s => s.SortOrder))
                            {
                                var hasSubDetails = !string.IsNullOrWhiteSpace(subgoal.DetailedDescription);
                                <tr>
                                    <td class="text-break">
                                        <i class="fa-solid fa-turn-up fa-rotate-90 text-muted me-1" aria-hidden="true"></i>
                                        @subgoal.Activity
                                    </td>
                                    <td class="text-center"><span class="text-muted">@subgoal.PlannedDelivery</span></td>
                                    <td class="text-center">@RenderStatus(subgoal.Completed)</td>
                                </tr>
                                @if (hasSubDetails)
                                {
                                    <tr>
                                        <td colspan="3">
                                            <div class="ps-4 detailed-html">@((MarkupString)NormalizeHtml(subgoal.DetailedDescription))</div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    };

    private RenderFragment RenderArchivedTable() => __builder =>
    {
        var archived = ActionPlan?.ArchivedItems;

        if (archived is not null && archived.Any())
        {
            var sortedArchived = archived.OrderByDescending(i => i.ArchivedAt).ToList();

                <div class="action-plan-archived">
                    <h3 class="h5 mb-3 action-plan-archived-title">
                        <i class="fa-solid fa-box-archive me-2" aria-hidden="true"></i>Avslutat
                    </h3>
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0">
                            <colgroup>
                                <col style="width: 10rem;">
                                <col>
                                <col style="width: 9rem;">
                                <col style="width: 6rem;">
                                <col style="width: 11rem;">
                            </colgroup>
                            <thead class="table-secondary">
                                <tr>
                                    <th scope="col">Modul/del</th>
                                    <th scope="col">Aktivitet</th>
                                    <th scope="col" class="text-center">Planerad leverans</th>
                                    <th scope="col" class="text-center">Avklarad</th>
                                    <th scope="col" class="text-center">Arkiverad</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in sortedArchived)
                                {
                                    var hasDetails = !string.IsNullOrWhiteSpace(item.DetailedDescription);
                                    var hasSubgoals = item.Subgoals is not null && item.Subgoals.Any();
                                    var isExpandable = hasDetails || hasSubgoals;

                                    <tr>
                                        <td><strong>@item.Module</strong></td>
                                        <td>
                                            <div class="d-flex align-items-start">
                                                <div class="flex-grow-1 text-break">@item.Activity</div>
                                                @if (isExpandable)
                                                {
                                                    <button type="button"
                                                            class="btn btn-link btn-sm p-0 ms-2 flex-shrink-0 align-baseline"
                                                            @onclick="() => ToggleItem(item.Id)"
                                                            title="Visa/dölj detaljer och delmål"
                                                            aria-label="Visa eller dölj detaljer och delmål för @item.Module">
                                                        <i class="fa-solid @(expandedItems.Contains(item.Id) ? "fa-chevron-up" : "fa-chevron-down")" aria-hidden="true"></i>
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                        <td class="text-center"><span class="text-muted">@item.PlannedDelivery</span></td>
                                        <td class="text-center">@RenderStatus(item.Completed)</td>
                                        <td class="text-center">
                                            <span class="text-muted">
                                                @(item.ArchivedAt.HasValue ? item.ArchivedAt.Value.ToString("yyyy-MM-dd HH:mm") : "")
                                            </span>
                                        </td>
                                    </tr>

                                    @if (expandedItems.Contains(item.Id) && isExpandable)
                                    {
                                        <tr class="table-light">
                                            <td colspan="5">
                                                <div class="p-3">
                                                    @RenderItemPanel(item, hasDetails, hasSubgoals)
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
        }
    };

    private RenderFragment RenderStatus(string? completed) => __builder =>
    {
        if (!string.IsNullOrEmpty(completed))
        {
            <span class="badge bg-success">
                <i class="fa-solid fa-check me-1" aria-hidden="true"></i>@completed
            </span>
        }
        else
        {
            <span class="text-muted">Pågående</span>
        }
    };

    private void ToggleItem(int itemId)
    {
        if (!expandedItems.Remove(itemId))
            expandedItems.Add(itemId);
    }

    // Normalisera TinyMCE-HTML för att säkra bildvisning
    private static string NormalizeHtml(string? html)
    {
        if (string.IsNullOrWhiteSpace(html)) return string.Empty;

        var fixedHtml = html;

        // data-mce-src -> src (både " och ')
        fixedHtml = Regex.Replace(fixedHtml, @"\sdata-mce-src\s*=\s*""", " src=\"", RegexOptions.IgnoreCase);
        fixedHtml = Regex.Replace(fixedHtml, @"\sdata-mce-src\s*=\s*'", " src='", RegexOptions.IgnoreCase);

        // src="images/..." -> src="/images/..."
        fixedHtml = Regex.Replace(fixedHtml, "src=\"(images/)", "src=\"/images/", RegexOptions.IgnoreCase);
        // src='images/...' -> src='/images/...'
        fixedHtml = Regex.Replace(fixedHtml, "src='(images/)", "src='/images/", RegexOptions.IgnoreCase);

        return fixedHtml;
    }
}
