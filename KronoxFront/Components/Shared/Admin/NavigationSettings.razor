@inject ILogger<NavigationSettings> Logger

<div class="card mb-4" id="navigation-settings-card">
    <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <h5 class="h5 mb-0">
            <i class="fa-solid fa-globe me-2" aria-hidden="true"></i>
            SidtillgûÊnglighet & navigation
        </h5>
        <div class="d-flex align-items-center gap-2">
            @if (navigationConfig != null)
            {
                if (!navigationConfig.IsActive)
                {
                    <span class="badge bg-danger fs-6">INAKTIVERAD</span>
                }
                else if (HasAnyRestrictions())
                {
                    <span class="badge bg-warning text-dark fs-6">AKTIV - BEGRûNSAD</span>
                }
                else
                {
                    <span class="badge bg-success fs-6">AKTIV - PUBLIK</span>
                }
            }
            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="ToggleSettings">
                <i class="fa-solid fa-@(showSettings ? "eye-slash" : "cog")" aria-hidden="true"></i>
                @(showSettings ? "DûÑlj" : "Visa") instûÊllningar
            </button>
        </div>
    </div>

    @if (showSettings)
    {
        <div class="card-body">
            @if (navigationConfig != null)
            {
                <EditForm Model="navigationConfig" OnValidSubmit="SaveNavigationSettings">
                    <DataAnnotationsValidator />
                    @if (PageKey.Equals("home", StringComparison.OrdinalIgnoreCase))
                    {
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-medium" for="displayNameHome">LûÊnktext i navigation</label>
                                <input id="displayNameHome" class="form-control" type="text"
                                       value="@(InitialDisplayName ?? "Startsida")" disabled />
                                <div class="form-text">Startsidan visas inte som en egen lûÊnk i menyn.</div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-medium d-block">Sidans status</label>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" role="switch" checked disabled />
                                    <label class="form-check-label">Sidan ûÊr aktiv</label>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" role="switch" checked disabled />
                                    <label class="form-check-label">Publik (synlig fûÑr alla)</label>
                                </div>
                                <div class="form-text">Startsidan ûÊr en systemsida och kan inte inaktiveras.</div>
                            </div>
                        </div>

                        <details class="small text-muted mb-3">
                            <summary style="cursor:pointer;">Om behûÑrighet och synlighet</summary>
                            <div class="mt-2">
                                <div class="alert alert-light border mb-0">
                                    <div class="mb-2">
                                        <span class="fw-medium">BehûÑrighet:</span>
                                        <span class="text-muted">@GetAccessRolesSummary()</span>
                                    </div>
                                    <div class="small text-muted mb-0">
                                        Detta ûÊr startsidan. Den ûÊr alltid aktiv och tillgûÊnglig via <code>/</code>
                                        fûÑr alla besûÑkare, men visas inte som en egen lûÊnk i navigationen.
                                        ûtkomst styrs av sidans kod.
                                    </div>
                                </div>
                            </div>
                        </details>
                    }
                    else
                    {
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-medium" for="displayName">LûÊnktext i navigation</label>
                                <InputText id="displayName" class="form-control" @bind-Value="navigationConfig.DisplayName" />
                                <ValidationMessage For="() => navigationConfig.DisplayName" />
                                <div class="form-text">
                                    Visas i menyn. Ordningen ûÊndras under
                                    <a href="/admin/navigation" class="text-decoration-none">Hantera navigation</a>.
                                </div>
                            </div>

                            <div class="col-md-6">
                                @if (IsFixedPage())
                                {
                                    @* FAST SIDA: endast aktiv/inaktiv *@
                                    <label class="form-label fw-medium d-block">Sidans status</label>
                                    <div class="form-check form-switch">
                                        <InputCheckbox class="form-check-input" role="switch"
                                                       @bind-Value="navigationConfig.IsActive"
                                                       @bind-Value:after="OnFixedIsActiveChanged" />
                                        <label class="form-check-label">Sidan ûÊr aktiv</label>
                                    </div>
                                    <div class="form-text">
                                        @if (navigationConfig.IsActive)
                                        {
                                            <span>Synlig i navigationen. ûtkomst styrs av sidans behûÑrighet i koden.</span>
                                        }
                                        else
                                        {
                                            <span>Avpublicerad ã dûÑljs i menyn och ger 404 vid direktbesûÑk.</span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    @* SPECIALSIDA: aktiv och publik synlighet *@
                                    <label class="form-label fw-medium d-block">Sidans status</label>

                                    <div class="form-check form-switch">
                                        <InputCheckbox class="form-check-input" role="switch"
                                                       @bind-Value="navigationConfig.IsActive"
                                                       @bind-Value:after="OnIsActiveChanged" />
                                        <label class="form-check-label">Sidan ûÊr aktiv</label>
                                    </div>

                                    <div class="form-check form-switch">
                                        <InputCheckbox class="form-check-input" role="switch"
                                                       @bind-Value="navigationConfig.IsVisibleToGuests"
                                                       @bind-Value:after="OnPublicVisibilityChanged" />
