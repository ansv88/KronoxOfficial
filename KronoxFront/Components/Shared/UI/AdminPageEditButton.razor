@if (IsAdmin)
{
    <div class="position-fixed end-0 m-3" style="z-index:1029; top: 75px;">
        <a href="@(IsCustomPage ? $"/admin/page/{PageKey}" : $"/admin/{PageKey}")" class="btn btn-dark btn-sm opacity-75">
            <i class="fa-solid fa-edit me-1"></i> Redigera sida
        </a>
    </div>
}

@code {
    [Parameter] public bool IsAdmin { get; set; } = false;
    [Parameter] public string PageKey { get; set; } = "";
    [Parameter] public bool IsCustomPage { get; set; } = false;
}
