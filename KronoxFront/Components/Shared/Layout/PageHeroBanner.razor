@using KronoxFront.ViewModels

<section class="hero-banner position-relative">
    @if (!string.IsNullOrWhiteSpace(ImageUrl))
    {
        <img src="@ImageUrl" class="img-fluid w-100" alt="@AltText" />
    }
    else
    {
        <div class="bg-light border-bottom" style="height:220px; display:flex; align-items:center; justify-content:center;">
            @if (IsAdmin)
            {
                <div class="text-center text-muted">
                    <i class="fa-solid fa-image fa-2x mb-2"></i>
                    <div>Ingen bannerbild vald ännu</div>
                    <div class="small">Välj "Redigera sida" och ladda upp en banner-bild.</div>
                </div>
            }
        </div>
    }

    </section>

    @code {
        [Parameter] public string ImageUrl { get; set; } = "";
        [Parameter] public string AltText { get; set; } = "";
        [Parameter] public bool IsAdmin { get; set; } = false;
        [Parameter] public string PageKey { get; set; } = "";
}